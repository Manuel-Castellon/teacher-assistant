# Copy to .env.local and fill in values. Never commit .env.local.

# PostgreSQL connection string (PG 18)
DATABASE_URL=postgresql://user:password@localhost:5432/math_teacher

# Auth.js (NextAuth v5) — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Claude API — for exam/lesson plan generation
ANTHROPIC_API_KEY=

# Wolfram Alpha — Full Results API (free tier: 2000 calls/month)
# Get an AppID at https://developer.wolframalpha.com
WOLFRAM_APP_ID=
