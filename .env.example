# Copy to .env.local and fill in values. Never commit .env.local.

# ── Claude API (default ITextGenerator) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Gemini API (alternative ITextGenerator — free tier) ─────────────────────
GEMINI_API_KEY=

# ── Auth (AWS Cognito + Google OAuth) ────────────────────────────────────────
AWS_REGION=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/math_teacher

# ── OCR Provider (decide at MVP 0 — test first, then ask user) ───────────────
# Uncomment the one chosen after testing:
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=
# GOOGLE_DOCUMENT_AI_PROJECT_ID=
# GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── Math Verifier (decide at MVP 2) ──────────────────────────────────────────
# Uncomment after user chooses:
# WOLFRAM_ALPHA_APP_ID=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
